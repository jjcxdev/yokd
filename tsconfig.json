{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "static",
    "tests",
    "*.config.cjs",
    ".git",
    "coverage",
    "public",
    "eslint.config.js",
    "postcss.config.js",
    "svelte.config.js"
  ]
}